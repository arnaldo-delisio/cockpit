# Cockpit shared secrets — template. Copy to `.env` (gitignored) and fill in.
# Both brains source `.env`: Hermes via its env load, Claude-side skills via the
# skill script sourcing this file. Clone-clean (MEM-23): real secrets never committed.

# Groq — Whisper transcription for audio (local files + captionless videos). Used by: watch
GROQ_API_KEY=

# Supadata — YouTube transcript fallback when native captions fail. Used by: watch
SUPADATA_API_KEY=
