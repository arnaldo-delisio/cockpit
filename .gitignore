# Walled client vaults — confidential, NEVER committed.
# git push is a leak path that OS perms don't cover. Locked rule:
# vault/ is local-only. See STATE.md → Memory architecture → Vault rule.
vault/
memory/scopes/*/vault/

# Secrets — shared-key home both brains source; NEVER committed (clone-clean, MEM-23).
# Track .env.example instead. See skills/*/SKILL.md for which keys each skill reads.
.env
.env.*
!.env.example

# Private memory DATA — never in the (open-source-ready) public history (OSS-1).
# Public = the system (engine + specs + skills); private = the data (identity/logs/knowledge).
# bootstrap.mjs is the source of truth for this tree — recreated on a clone; the public repo
# stays data-free + clone-clean. Private versioning + reconciler commit-target finalized at build.
memory/scopes/
memory/knowledge/

# Engine runtime — deps pinned in package.json, never committed (the HF model cache lives in
# ~/.cache/huggingface, outside the repo).
memory/engine/node_modules/

# OS cruft
.DS_Store
